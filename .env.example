# =========================
# AWS CONFIG
# =========================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=

# =========================
# DATABASE
# =========================
DATABASE_URL=

# =========================
# REDIS / QUEUE
# =========================
REDIS_URL=redis://redis:6379/0

# =========================
# SCAN SETTINGS
# =========================
MAX_WORKERS=5
SCAN_INTERVAL_SECONDS=3600
ENABLE_SCHEDULER=false

# =========================
# ALERT SETTINGS
# =========================
ENABLE_ALERTS=true
ALERT_SEVERITIES=CRITICAL,HIGH,MEDIUM,LOW

# =========================
# NOTIFICATION CHANNELS
# =========================

# Slack
ENABLE_SLACK=false
SLACK_WEBHOOK=

# Telegram
ENABLE_TELEGRAM=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=